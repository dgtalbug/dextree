# Keep test and source files out of the published .vsix
src/**
**/*.test.*
**/*.spec.*
**/*.ts
**/*.map

# Build tooling
esbuild.mjs
tsconfig*.json
vitest.config.*
.turbo/**

# Workspace and editor config
.vscode/**
**/.gitignore
**/tsconfig*.json

# Exclude node_modules — runtime deps are bundled into extension.cjs by esbuild
node_modules/**
